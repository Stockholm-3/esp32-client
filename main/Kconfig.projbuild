# put here your custom config value
menu "Example Configuration"
config ESP_WIFI_SSID
    string "WiFi SSID"
    default "myssid"
    help
	SSID (network name) for the example to connect to.

config ESP_WIFI_PASSWORD
    string "WiFi Password"
    default "mypassword"
    help
	WiFi password (WPA or WPA2) for the example to use.
config WS7B_QEMU_SIM
    bool "QEMU simulation mode (skip hardware init)"
    default n
    help
        Skip I2C, IO expander, RGB panel, and touch init.
        Registers a null LVGL flush callback so the app boots
        without real hardware. Enable when running under QEMU.
endmenu
