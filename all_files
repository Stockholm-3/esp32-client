#define ECHO_UART_PORT_NUM      (UART_NUM_1)    // Use UART port 1
#define BUF_SIZE    (1024)  // Buffer size for UART data (in bytes)
#define TIME_OUT    (100)   // Timeout value for UART operations (in milliseconds)

